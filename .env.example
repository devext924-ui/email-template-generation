# Application
APP_NAME="Email Template Generation"
APP_ENV=development
LOG_LEVEL=INFO

# Frontend / CLI integration
EMAIL_TEMPLATE_BACKEND_URL=http://127.0.0.1:8000

# React frontend (copy frontend/.env.example to frontend/.env for Vite)
VITE_API_BASE_URL=http://localhost:8000

# Paths (relative to project root unless absolute)
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=models
OUTPUTS_DIR=outputs
SAMPLE_CSV=data/sample_emails.csv

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
FINE_TUNED_MODEL_DIR=models/fine_tuned_sentence_transformer
EMBEDDING_CACHE_FILE=data/processed/embeddings.npy
USE_FINE_TUNED=false
EMBED_BATCH_SIZE=64

# Clustering
CLUSTERING_METHOD=kmeans
# Optional fixed cluster count. Leave commented to use the backend heuristic.
# N_CLUSTERS=10
RANDOM_STATE=42

# Fine-tuning
FINE_TUNE_EPOCHS=1
FINE_TUNE_BATCH_SIZE=16
FINE_TUNE_WARMUP_STEPS=50

# Templates
MAX_TEMPLATES=50
DUPLICATE_SIMILARITY_THRESHOLD=0.92

# Sentiment
SENTIMENT_BACKEND=rule_based
